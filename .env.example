# Meta / WhatsApp
WHATSAPP_TOKEN=          # Token permanente do System User (Business Manager)
WHATSAPP_PHONE_ID=       # ID do número de telefone (ex: 123456789012345)
WHATSAPP_APP_SECRET=     # App Secret do app Meta for Developers
WEBHOOK_VERIFY_TOKEN=    # Token livre que você define para verificação do webhook

# Anthropic
ANTHROPIC_API_KEY=

# App
PORT=3000
NODE_ENV=development
DATABASE_URL=./data/chatbot.db

# Comportamento
SESSION_TIMEOUT_MINUTES=30
HUMAN_HANDOFF_PAUSE_MINUTES=120
MAX_FAQ_HISTORY_TURNS=5
RATE_LIMIT_MSG_PER_SECOND=1
